modules = ["nodejs-24", "python-3.11", "python3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start MongoDB"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Redis"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Celery"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Legislation API"

[[workflows.workflow]]
name = "Start MongoDB"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/legislation-worker/run_mongodb.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start Redis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/legislation-worker/run_redis.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start Celery"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/legislation-worker/run_worker.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Legislation API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/legislation-worker/run_api.sh"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["mongodb", "postgresql", "redis", "uv"]

[userenv]

[userenv.shared]
LEGISLATION_API_URL = "https://0c2e72a2-c56c-4994-b869-80633822760a-00-11mwnqkdda7si.riker.replit.dev:8001"
LEGISLATION_API_INTERNAL_URL = "http://localhost:8001"
MONGODB_URI = "mongodb://localhost:27017"
MONGODB_DB = "state_pulse"
