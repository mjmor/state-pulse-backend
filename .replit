modules = ["nodejs-24", "python-3.11"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start MongoDB"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Redis"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Celery"

[[workflows.workflow]]
name = "Start MongoDB"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/legislation-worker/run_mongodb.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start Redis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/legislation-worker/run_redis.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start Celery"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/legislation-worker/run_worker.sh"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["mongodb", "redis", "uv"]
